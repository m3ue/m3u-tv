# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# GitHub Actions — keep CI workflows, Dependabot config, and release note categories
.github/*
!.github/dependabot.yml
!.github/release.yml
!.github/workflows/
.github/workflows/*
!.github/workflows/ci.yml
!.github/workflows/release.yml

# Flutter
flutter_client/build/
flutter_client/.dart_tool/
flutter_client/.flutter-plugins
flutter_client/.flutter-plugins-dependencies
flutter_client/pubspec.lock

# Android release signing — never commit real credentials
*.jks
*.keystore
*.pem
flutter_client/android/signing.properties
flutter_client/android/*.jks
flutter_client/android/*.keystore
flutter_client/android/*.pem

# Ignore app store generated screenshots
flutter_client/screenshots/store

# Dart/Flutter generated
flutter_client/**/*.g.dart
flutter_client/**/*.freezed.dart

# Docs exceptions
!docs/
!docs/release/
!docs/release/platform-release-matrix.md
