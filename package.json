{
  "name": "m3u-tv",
  "version": "0.0.1",
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "scripts": {
    "start": "EXPO_TV=1 expo start",
    "android": "EXPO_TV=1 expo run:android",
    "bundle-android": "cd android && ./gradlew bundleRelease && cd ..",
    "build-apk": "cd android && ./gradlew assembleRelease && cd ..",
    "ios": "EXPO_TV=1 expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "mobile:android": "expo run:android",
    "mobile:ios": "expo run:ios",
    "electron:dev": "expo export --platform web && electron electron/main.js",
    "electron:build": "expo export --platform web && electron-builder",
    "prebuild": "EXPO_TV=1 expo prebuild --clean",
    "audit": "npm audit",
    "clean": "rm -rf node_modules android ios",
    "lint": "eslint . --debug",
    "lint:fix": "eslint . --fix",
    "pretty": "npx prettier *.{ts,tsx} --write",
    "typecheck": "tsc --noEmit",
    "postinstall": "npx patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/drawer": "^7.4.0",
    "@react-navigation/native": "^7.1.1",
    "@react-navigation/native-stack": "^7.3.2",
    "expo": "^54.0.20",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "~1.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "hls.js": "^1.6.15",
    "lucide-react-native": "^0.563.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "npm:react-native-tvos@0.81-stable",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pixel-perfect": "^1.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "~15.12.1",
    "react-native-video": "^6.19.0",
    "react-native-vlc-media-player": "1.0.98",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native-tvos/config-tv": "^0.1.4",
    "@types/react": "~19.1.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.19.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "resolutions": {
    "tar": ">=7.5.10",
    "minimatch": ">=9.0.7"
  },
  "overrides": {
    "tar": ">=7.5.10",
    "minimatch": ">=9.0.7"
  },
  "build": {
    "appId": "com.m3utv.desktop",
    "productName": "M3U TV",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  }
}
